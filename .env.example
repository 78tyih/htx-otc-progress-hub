# ============================================================================
# HTX OTC BD Progress Hub — 环境变量模板（.env.example）
#
# 说明：
#   1. 本文件是【模板】，只含键名与占位值，可以安全提交到 git。
#   2. 真实的 .env 文件【不入 git】：请在项目根目录自行创建 .env，
#      并确认 .env 已加入 .gitignore，永不提交、永不推送。
#   3. 严禁把真实密码 / Token 写进前端代码、git 提交或聊天记录；
#      真实值只放平台环境变量（Cloudflare / Render 等后台）或本地 .env。
# 维护人：Sera ｜ 更新日期：2026-07-21
# ============================================================================

# --- Cloudflare（方案 B：Cloudflare Pages + Access，见 docs/04_private_deployment.md）---
# Cloudflare 账号 ID（Dash 右下角或 Pages 面板可见）
CLOUDFLARE_ACCOUNT_ID=
# Cloudflare API Token（如需用 API/Wrangler 管理 Pages 或 Access 时填写）
CLOUDFLARE_API_TOKEN=

# --- 访问控制（见 docs/05_access_control.md）---
# 唯一允许访问看板的邮箱（占位示例，真实值为 Simon 邮箱，只填一个）
ALLOWED_EMAIL=simon@example.com

# --- Basic Auth（方案 C 备选：Render / Railway / VPS nginx 时使用）---
BASIC_AUTH_USER=simon
BASIC_AUTH_PASSWORD=__由Sera单独告知_勿提交真实值__

# --- 企业微信提醒（scheduler/reminder-worker.js，见群机器人 webhook）---
# 企微群机器人 webhook 地址（群聊 → 群机器人 → 添加后复制，含 key，切勿提交真实值）
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=__填入真实key_勿提交__

# --- 看板 Agent（服务端专用，OpenAI-compatible；可选，不配置时 Agent 走内置规则引擎）---
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# --- 手机 Webhook 通知（服务端专用，严禁出现在客户端源码/构建产物/日志/仓库）---
NOTIFY_WEBHOOK_URL=
NOTIFY_WEBHOOK_SECRET=
# 线上看板地址（用于通知消息中的 dashboardUrl；不填则按请求域名自动推导）
APP_URL=

# --- Vercel KV（线上状态存储；在 Vercel 后台创建 KV 并连接项目后自动注入，无需手填）---
KV_REST_API_URL=
KV_REST_API_TOKEN=
